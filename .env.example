# --- Required for the default Gemini provider (https://aistudio.google.com/apikey) ---
GEMINI_API_KEY=

# --- Optional: raises GitHub API rate limit from 60 to 5000 requests/hour ---
GITHUB_TOKEN=

# --- Optional alternative providers ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_HOST=http://localhost:11434

# --- Optional: Kaggle collector (https://www.kaggle.com/settings -> API) ---
KAGGLE_USERNAME=
KAGGLE_KEY=

# --- Defaults (override the built-in defaults) ---
DEFAULT_PROVIDER=gemini
DEFAULT_MODEL=gemini-2.5-flash
CACHE_ENABLED=true
CACHE_DIR=.hiregauge_cache
